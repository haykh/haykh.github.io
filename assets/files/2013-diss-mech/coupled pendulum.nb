           RowBox[{
            RowBox[{"x2", "[", "t", "]"}], "/", "l"}]}], "-", 
          RowBox[{"k", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"x2", "[", "t", "]"}], "-", 
             RowBox[{"x1", "[", "t", "]"}]}], ")"}]}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"x2", "[", "0", "]"}], "==", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"x1", "[", "0", "]"}], "==", 
         RowBox[{"-", ".5"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"x2", "'"}], "[", "0", "]"}], "\[Equal]", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "'"}], "[", "0", "]"}], "\[Equal]", "0"}]}], 
       "\[IndentingNewLine]", "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x1", "[", "t", "]"}], ",", 
